# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=your_mongodb_connection_string_here

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Service Configuration
# Choose between 'gmail', 'resend', or other providers
# 
# For LOCAL DEVELOPMENT (Gmail):
# Use 'gmail' - works fine locally but NOT on Render (SMTP ports blocked)
# 
# For PRODUCTION/RENDER (Resend):
# Use 'resend' - works on Render (uses HTTPS API, no SMTP ports needed)
# Sign up at https://resend.com for free API key (100 emails/day)
EMAIL_SERVICE=gmail

# === GMAIL CONFIGURATION (for local development) ===
# For Gmail: Use your Gmail address and an App Password (not your regular password)
# To create a Gmail App Password:
# 1. Go to your Google Account settings
# 2. Select Security
# 3. Under "Signing in to Google," select App Passwords
# 4. Generate a new app password for "Mail"
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# === RESEND CONFIGURATION (for production/Render) ===
# Get your API key from https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxxxxxxxxxxx
# For testing, use Resend's test email. For production, use your verified domain
EMAIL_FROM=onboarding@resend.dev

# === BREVO CONFIGURATION (Alternative to Resend) ===
# Works on Render via API (HTTPS)
# Sign up at https://brevo.com (300 emails/day free)
# Get API key from https://app.brevo.com/settings/keys/api
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173
